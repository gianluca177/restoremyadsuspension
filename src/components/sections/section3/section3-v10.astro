---
import CTAGroup from "../../../components/ui/CTAGroup.astro";
---

<section class="bg-[#04101f] py-28 text-white">

<div class="max-w-6xl mx-auto px-6">

<!-- HEADER -->

<h2 class="text-3xl md:text-4xl font-semibold text-center mb-4">
The Suspension Recovery Process
</h2>

<p class="text-gray-400 text-center max-w-2xl mx-auto mb-16">
A structured approach to Google Ads reinstatement — from identifying the suspension trigger to restoring account stability.
</p>


<!-- PROCESS NAV -->

<div class="framework-nav flex justify-center gap-8 mb-16 text-xs tracking-wider">

<button class="tab-btn active" data-tab="audit">
<span class="dot"></span>
AUDIT
</button>

<button class="tab-btn" data-tab="appeal">
<span class="dot"></span>
APPEAL
</button>

<button class="tab-btn" data-tab="restore">
<span class="dot"></span>
RESTORE
</button>

<button class="tab-btn" data-tab="support">
<span class="dot"></span>
SUPPORT
</button>

</div>



<!-- FRAME -->

<div id="framework-frame"
class="grid md:grid-cols-2 gap-10 items-center
rounded-2xl border border-gray-700
bg-[#081826]
p-10 md:p-14
shadow-[0_0_50px_rgba(0,0,0,0.45)]">


<!-- TEXT SIDE -->

<div>

<h3 id="tab-title"
class="text-2xl font-semibold mb-4">
AUDIT
</h3>

<p id="tab-description"
class="text-gray-400 mb-8 leading-relaxed">
Identify the root cause of the suspension before any appeal is submitted.
</p>


<ul id="tab-bullets" class="space-y-4">

<li class="bullet flex items-center gap-3 opacity-0">

<svg class="tick w-6 h-6" viewBox="0 0 24 24" fill="#FF4D4D">
<path d="M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z"/>
</svg>

<span class="bullet-text text-gray-500 text-base">
Identify the suspension trigger
</span>

</li>

<li class="bullet flex items-center gap-3 opacity-0">

<svg class="tick w-6 h-6" viewBox="0 0 24 24" fill="#FF4D4D">
<path d="M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z"/>
</svg>

<span class="bullet-text text-gray-500 text-base">
Review account risk signals
</span>

</li>

<li class="bullet flex items-center gap-3 opacity-0">

<svg class="tick w-6 h-6" viewBox="0 0 24 24" fill="#FF4D4D">
<path d="M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z"/>
</svg>

<span class="bullet-text text-gray-500 text-base">
Determine recovery eligibility
</span>

</li>

</ul>

</div>



<!-- IMAGE SIDE -->

<div class="relative">

<img
id="tab-image"
src="/images/Suspended.png"
class="rounded-xl w-full border border-gray-700 shadow-lg cursor-pointer transition-transform duration-300 hover:scale-[1.02]"
alt="Suspension Evidence"
/>

<p id="image-caption"
class="text-xs text-gray-500 mt-3 text-center">
Example suspension notice received from Google Ads.
</p>

</div>

</div>



<!-- CTA -->

<div class="mt-20 flex justify-center">

<CTAGroup
href="https://calendly.com/gianluca-adrestore/30min-consultation"
text="Book Suspension Review"
assessmentText="Free 30-Minute Live Account Assessment"
/>

</div>


</div>

</section>



<!-- LIGHTBOX -->

<div id="lightbox" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50 p-6">

<img id="lightbox-img" class="max-w-full max-h-full rounded-lg"/>

</div>



<style>

.framework-nav button{
display:flex;
align-items:center;
gap:6px;
color:#6B7280;
transition:.25s;
}

.framework-nav button.active{
color:white;
}

.framework-nav .dot{
width:6px;
height:6px;
border-radius:50%;
background:#374151;
transition:.25s;
}

.framework-nav button.active .dot{
background:#3BA6FF;
}

</style>



<script>

document.addEventListener("DOMContentLoaded",()=>{

let animationPlayed=false

const steps={

audit:{
color:"#FF4D4D",
title:"Suspension Detected",
image:"/images/Suspended.png",
caption:"Google Ads suspension notification received.",
description:"The first step is identifying the exact policy trigger and reviewing all risk signals connected to the account.",
bullets:[
"Identify the suspension trigger",
"Review account risk signals",
"Determine recovery eligibility"
]
},

appeal:{
color:"#FFFFFF",
title:"Structured Appeal Submitted",
image:"/images/Appeal.png",
caption:"Policy-aligned appeal prepared for Google review.",
description:"A structured appeal is prepared that aligns directly with Google's policy framework and reviewer expectations.",
bullets:[
"Prepare policy-aligned explanation",
"Document compliance corrections",
"Submit structured reinstatement case"
]
},

restore:{
color:"#3BA6FF",
title:"Account Reinstated",
image:"/images/Accepted.png",
caption:"Google confirms successful reinstatement.",
description:"Once accepted, the account regains ad delivery capability and campaigns can resume normal operation.",
bullets:[
"Account reinstatement confirmed",
"Ads regain delivery capability",
"Campaign access restored"
]
},

support:{
color:"#22C1A5",
title:"Post-Restore Stability",
image:"/images/Dashboard.png",
caption:"Monitoring and safeguarding account health.",
description:"After reinstatement we monitor stability and ensure future policy risks are prevented.",
bullets:[
"Monitor account stability",
"Prevent future suspension signals",
"Provide ongoing account guidance"
]
}

}



const buttons=document.querySelectorAll(".tab-btn")
const bulletsContainer=document.getElementById("tab-bullets")
const image=document.getElementById("tab-image")
const caption=document.getElementById("image-caption")
const title=document.getElementById("tab-title")
const description=document.getElementById("tab-description")



function activateTab(btn){

buttons.forEach(b=>b.classList.remove("active"))
btn.classList.add("active")

const key=btn.dataset.tab
const step=steps[key]

image.src=step.image
caption.textContent=step.caption
title.textContent=step.title
description.textContent=step.description

bulletsContainer.innerHTML=step.bullets.map(b=>`

<li class="bullet flex items-center gap-3 opacity-0">

<svg class="tick w-6 h-6" viewBox="0 0 24 24" fill="${step.color}">
<path d="M9 16.2l-3.5-3.5L4 14.2 9 19l12-12-1.5-1.5z"/>
</svg>

<span class="bullet-text text-gray-500 text-base">${b}</span>

</li>

`).join("")

animateBullets()

}



function animateBullets(){

const bullets=document.querySelectorAll(".bullet")

bullets.forEach((bullet,i)=>{

setTimeout(()=>{

bullet.style.opacity=1
bullet.querySelector(".bullet-text").classList.replace("text-gray-500","text-white")

},200+(i*160))

})

}



buttons.forEach(btn=>{
btn.addEventListener("click",()=>activateTab(btn))
})



/* LIGHTBOX */

const lightbox=document.getElementById("lightbox")
const lightboxImg=document.getElementById("lightbox-img")

image.addEventListener("click",()=>{

lightboxImg.src=image.src
lightbox.classList.remove("hidden")
lightbox.classList.add("flex")

})

lightbox.addEventListener("click",()=>{

lightbox.classList.remove("flex")
lightbox.classList.add("hidden")

})

})

</script>