---
import TickIcon from '../ui/Tickicon.astro';
import LiveConsultIcon from '../ui/LiveConsultIcon.astro';
---

<section class="hero">
  <div class="wrap">
    <div class="heroGrid">

      <!-- LEFT -->
      <div class="content">

        <h1>
          <span class="blue">Restore Your Suspended</span><br />
          Google Ads Account<br />
          <span class="mint">Prevent Future Suspensions.</span>
        </h1>

        <p class="sub">
          We assess recoverability and professionally manage the appeal process —
          including 7-day post-restoration support to help keep your account stable.
        </p>

        <ul class="bullets">
          <li>
            <TickIcon />
            <span>7-Day Post-Restoration Support</span>
          </li>

          <li>
            <TickIcon />
            <span>Agency Access — No Password Required</span>
          </li>

          <li>
            <TickIcon />
            <span>Full Refund If Unsuccessful<sup>1</sup></span>
          </li>
        </ul>

        <!-- MOBILE: image BEFORE CTA -->
        <div class="visual visualMobile">
          <div class="glow"></div>
          <div class="phone">
            <img
              src="/images/hero-image.png"
              alt="Google Ads Account Reinstated Email Confirmation"
            />
          </div>
        </div>

        <a class="ctaPrimary" href="#consult">
          Book Suspension Review
        </a>

        <div class="assessment">
          <LiveConsultIcon />
          <span>Free 30-Minute Live Account Assessment</span>
        </div>

      </div>

      <!-- DESKTOP: image right side -->
      <div class="visual visualDesktop">
        <div class="glow"></div>

        <div class="phone">
          <img
            src="/images/hero-image.png"
            alt="Google Ads Account Reinstated Email Confirmation"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .wrap{
    max-width:1200px;
    margin:0 auto;
    padding:0 20px;
  }

  .hero{
    position:relative;
    padding:90px 0 50px;
    display:flex;
    align-items:center;
    background-image:url('/images/hero-background.png');
    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;
  }

  .hero::before{
    content:"";
    position:absolute;
    inset:0;
    background:linear-gradient(
      180deg,
      rgba(5,20,40,.88),
      rgba(5,20,40,.96)
    );
    z-index:0;
  }

  .heroGrid{
    position:relative;
    z-index:1;
    display:grid;
    grid-template-columns:1fr;
    gap:30px;
    align-items:center;
  }

  .content{
    text-align:left;
  }

  h1{
    margin:0 0 14px;
    font-size:28px;
    line-height:1.18;
    letter-spacing:-.4px;
  }

  .sub{
    margin:0 0 16px;
    font-size:15px;
    line-height:1.5;
    opacity:.88;
  }

  .blue{color:#4fb4ff}
  .mint{color:#48e0c6}

  .bullets{
    margin:16px 0 18px;
    padding:0;
    list-style:none;
  }

  .bullets li{
    display:flex;
    align-items:flex-start;
    gap:10px;
    margin-bottom:12px;
    font-size:14.5px;
  }

  .ctaPrimary{
    padding:14px 26px;
    border-radius:999px;
    background:linear-gradient(180deg,#7fd1ff,#55aef7);
    color:#06213a;
    font-weight:800;
    display:block;
    text-align:center;
    margin-top:14px;
  }

  .assessment{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    margin-top:10px;
    font-size:13px;
    opacity:.85;
  }

  /* visuals */
  .visual{
    position:relative;
    display:flex;
    justify-content:center;
  }

  /* BIGGER, WIDER glow on mobile */
  .glow{
    position:absolute;
    width:380px;
    height:380px;
    border-radius:50%;
    background:radial-gradient(circle,
      rgba(72,224,198,.55) 0%,
      rgba(72,224,198,.22) 35%,
      rgba(72,224,198,0) 72%
    );
    filter: blur(2px);
    z-index:0;
  }

  .visualMobile{
    margin:18px 0 6px;
  }

  .phone{
    position:relative;
    width:100%;
    max-width:420px;
    z-index:1;
  }

  .phone img{
    width:100%;
    height:auto;
    display:block;
  }

  sup{
    font-size:10px;
    vertical-align:super;
    position:relative;
    top:-0.1em;
  }

  /* Mobile/desktop switching */
  .visualDesktop{ display:none; }
  .visualMobile{ display:flex; }

  /* Desktop */
  @media(min-width:980px){
    .hero{
      padding:120px 0 80px;
      min-height:100vh;
    }

    .heroGrid{
      grid-template-columns:1.05fr .95fr;
      gap:46px;
    }

    h1{
      font-size:54px;
      line-height:1.06;
      letter-spacing:-.7px;
    }

    .sub{
      font-size:18px;
      margin-bottom:18px;
    }

    .glow{
      width:520px;
      height:520px;
      background:radial-gradient(circle,
        rgba(72,224,198,.45) 0%,
        rgba(72,224,198,.18) 38%,
        rgba(72,224,198,0) 74%
      );
      filter: blur(3px);
    }

    .phone{
      max-width:380px;
    }

    .ctaPrimary{
      display:inline-block;
    }

    .assessment{
      justify-content:flex-start;
    }

    .visualDesktop{ display:flex; }
    .visualMobile{ display:none; }
  }
</style>