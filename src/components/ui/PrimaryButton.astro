---
interface Props {
  href: string;
  text: string;
  class?: string;
}

const { href, text, class: className = "" } = Astro.props;
---

<a href={href} class={`ctaPrimary ${className}`}>
  {text}
</a>

<style>
.ctaPrimary{
  padding:14px 26px;
  border-radius:999px;
  background:linear-gradient(180deg,#7fd1ff,#55aef7);
  color:#06213a;
  font-weight:800;
  text-align:center;
  display:block;              /* mobile default */
  width:100%;
  transition:transform .2s ease, box-shadow .2s ease;
}

.ctaPrimary:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 25px rgba(85,174,247,.25);
}

@media(min-width:980px){
  .ctaPrimary{
    display:inline-block;
    width:auto;
  }
}
</style>