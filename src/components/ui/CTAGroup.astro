---
import PrimaryButton from "./PrimaryButton.astro";
import LiveConsultIcon from "./LiveConsultIcon.astro";

interface Props {
  href?: string;
  text?: string;
  assessmentText?: string;
}

const {
  href = "https://calendly.com/gianluca-adrestore/30min-consultation",
  text = "Book Suspension Review",
  assessmentText = "Free 30-Minute Live Account Assessment"
} = Astro.props;
---

<div class="ctaGroup">
  <PrimaryButton href={href} text={text} />

  <div class="assessment">
    <LiveConsultIcon />
    <span>{assessmentText}</span>
  </div>
</div>

<style>
.ctaGroup {
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.assessment {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 10px;
  font-size: 13px;
  opacity: 0.85;
  text-align: center;
}
</style>